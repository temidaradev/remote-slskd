# Soulseek network login (an account is claimed on first login with any client).
# The dev shell passes these to slskd so searches actually work.
SOULSEEK_USERNAME=your_soulseek_name
SOULSEEK_PASSWORD=your_soulseek_password

# Directory slskd shares with the network (used by the dev shell)
SHARE_PATH=/mnt/1TB-HDD/Synced/Music

# slskd API endpoint
SLSKD_URL=http://localhost:5030

# Minimum bitrate (kbps) to accept for files that report one
MIN_BITRATE=320

# Only queue lossless (.flac) matches when true; also allow lossy formats when false
PREFER_FLAC=true

# Minimum files a folder must have to appear as a result (1 = include singles)
MIN_FILES=1

# How many results to list for selection
MAX_RESULTS=20

# Search timing: slskd search window (ms), max seconds to wait, and the number
# of responding users after which we stop waiting early.
SEARCH_TIMEOUT=8000
MAX_WAIT=15
ENOUGH_RESULTS=15
